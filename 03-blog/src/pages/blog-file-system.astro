---
import Layout from "../layouts/Layout.astro";
import { SITE_CONFIG } from "../config/site";
import OldPost from "../components/OldPost.astro";

const matches = import.meta.glob('./posts-old/*.{md,mdx}', { eager: true });
const posts = Object.values(matches) as any[];
---

<Layout title="Mauro's Blog">
	<!-- component -->
	<section class="bg-gray-900">
		<div class="container px-6 py-10 mx-auto">
			<h1
				class="text-3xl font-semibold capitalize lg:text-4xl text-white"
			>
				{SITE_CONFIG.title}
			</h1>

			<div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
				{
					posts.map((post) => <OldPost {...post} />)
				}
			</div>
		</div>
	</section>
</Layout>
