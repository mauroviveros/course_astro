---
import Layout from "../layouts/Layout.astro";
const name = "Mauro Viveros";
const title = "Home page";
---

<Layout title={title}>
	<h1>Astro</h1>
	<p>Welcome to Astro, {name}!</p>
	<p>Momento actual (estatico): {new Date().toLocaleTimeString()}</p>
	<p>Momento actual (dinamico): <span id="dynamic-time"></span></p>
	<footer></footer>
</Layout>

<script>
	const currentYear = new Date().getFullYear();
	const footer = document.querySelector("footer");
	const dynamicTime = document.getElementById("dynamic-time");

	if(footer) footer.innerHTML = `&copy; Year: ${currentYear}`;
	if(dynamicTime) dynamicTime.textContent = new Date().toLocaleTimeString();
</script>