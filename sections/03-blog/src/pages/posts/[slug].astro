---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { Formatter } from "../../utils";
export async function getStaticPaths() {
  return (await getCollection('blog')).map((post) => {
    return {
        params: { slug: post.slug },
        props: { post },
    }
  });
}

const { data, render, slug } = Astro.props.post;
const { title, author: authorReference, image, date } = data;
const { Content, headings } = await render();
const authorEntry = await getEntry(authorReference.collection, authorReference.id);
if(!authorEntry) throw new Error(`Author with id ${authorReference.id} not found`);
const author = authorEntry.data;
---

<BlogLayout title={title}>
    <h1 class="text-xs! text-gray-500 mb-0">{title}</h1>
    <div class="text-md text-gray-400 mb-0 flex mt-2">
        <Image
            src={author.avatar}
            alt={author.name}
            class="rounded-full"
            width={50}
            height={50}
        />

        <div class="flex flex-col ml-5 ">
            <a href={`/blog/${authorEntry.id}`}>{author.name}</a>
            <span class="text-xs text-gray-300">{Formatter.formatDate(date)}</span>
        </div>
    </div>
    <!-- <h4 class="text-md! text-gray-400 mb-0">{author.name}</h4> -->

    <!-- Tabla de contenidos -->
     <h3>Tabla de contenidos</h3>
     <ol>
        {
        headings
            .filter(({ depth }) => !(depth > 2))
            .map(({ slug, text}, index) => (
                <li>
                    <a href={`#${slug}`}>
                        {index+1}. {text}
                    </a>
                </li>
            ))
        }
     </ol>

    <Image
        class="rounded-md w-full h-62.5 object-cover my-5"
        src={image}
        alt={title}
        width={600}
        height={200}
        quality="high"
        transition:name={`${slug}-image`}
    />

    <Content />

    <div class="my-20">
        <a href="#btn-back">Ir arriba</a>
    </div>
</BlogLayout>