---
import { getCollection } from "astro:content";
import { SITE_CONFIG } from "../../config/site";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

const authors = await getCollection("author");
---

<Layout title="Mauro's Blog">
	<!-- component -->
	<section class="bg-gray-900">
		<div class="container px-6 py-10 mx-auto">
			<h1
				class="text-3xl font-semibold capitalize lg:text-4xl text-white"
			>
				{SITE_CONFIG.title}
			</h1>
        </div>
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {authors.map(({data: { avatar, name, subtitle, bio, twitter, linkedIn, github }, id}) => (
            <div class="max-w-lg mx-auto my-10 bg-white rounded-lg shadow-md p-5">
                <Image class="w-32 h-32 rounded-full mx-auto" src={avatar} alt={name} transition:name={`${id}-author`}/>
                <h2 class="text-center text-2xl font-semibold mt-3">{name}</h2>
                <p class="text-center text-gray-600 mt-1">{subtitle}</p>
                <div class="flex justify-center mt-5">
                    <a href={`https://x.com/${twitter}`} class="text-blue-500 hover:text-blue-700 mx-3" target="_blank">Twitter</a>
                    <a href={linkedIn} class="text-blue-500 hover:text-blue-700 mx-3" target="_blank">LinkedIn</a>
                    <a href={github} class="text-blue-500 hover:text-blue-700 mx-3" target="_blank">GitHub</a>
                </div>
                <div class="mt-5">
                    <h3 class="text-xl font-semibold">Bio</h3>
                    <p class="text-gray-600 mt-2">{bio}</p>
                    <div class="flex justify-end">
                        <a href={`/blog/${id}`} class="text-blue-500 hover:text-blue-700">Ver posts</a>
                    </div>
                </div>
            </div>
        ))}
    </section>
</Layout>