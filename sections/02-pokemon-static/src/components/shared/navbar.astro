---
const routes = [
    { name: 'Listado', path: '/' },
    { name: 'Paginado', path: '/pokemons/1' },
    { name: 'Favoritos', path: '/favorites' },
];
---

<nav class="bg-white shadow dark:bg-slate-600">
    <div class="container flex items-center justify-center p-6 mx-auto text-gray-600 capitalize dark:text-gray-300">
        {routes.map(({ name, path }) => (
            <a href={path} class="border-b-2 border-transparent hover:text-gray-800 dark:hover:text-gray-200 hover:border-blue-500 mx-1.5 sm:mx-6">{name}</a>
        ))}
        <!-- <a href="#" class="text-gray-800 dark:text-gray-200 border-b-2 border-blue-500 mx-1.5 sm:mx-6">Listado</a>
        <a href="#" class="border-b-2 border-transparent hover:text-gray-800 dark:hover:text-gray-200 hover:border-blue-500 mx-1.5 sm:mx-6">Paginado</a>
        <a href="#" class="border-b-2 border-transparent hover:text-gray-800 dark:hover:text-gray-200 hover:border-blue-500 mx-1.5 sm:mx-6">Favoritos</a> -->
    </div>
</nav>